# ============================================================
# Smart Traffic System — Environment Variables Template
# ============================================================
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in YOUR real values below
#   3. .env is in .gitignore — your credentials are NEVER committed
# ============================================================

# ── Telegram Bot ─────────────────────────────────────────────
# Step 1: Message @BotFather on Telegram → /newbot → copy token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Step 2: Message @userinfobot on Telegram → copy your numeric chat ID
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Model & Video ─────────────────────────────────────────────
# Path to YOLOv8 weights file (relative to project root)
# Auto-downloaded on first run: python -c "from ultralytics import YOLO; YOLO('yolov8m.pt')"
MODEL_PATH=yolov8m.pt

# Default video file to process (relative to project root)
# Can be overridden at runtime: python video_detection.py --video v3.mp4
DEFAULT_VIDEO=v1.mp4
